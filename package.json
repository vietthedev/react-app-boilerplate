{
	"name": "react-app-boilerplate",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"lint": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true .",
		"preview": "vite preview",
		"test": "cross-env CI=true vitest --passWithNoTests",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"react": "19.2.7",
		"react-dom": "19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@tailwindcss/postcss": "4.3.2",
		"@tailwindcss/typography": "0.5.20",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react-swc": "4.3.1",
		"cross-env": "10.1.0",
		"daisyui": "5.6.18",
		"jsdom": "29.1.1",
		"lefthook": "2.1.10",
		"postcss": "8.5.17",
		"tailwindcss": "4.3.2",
		"ts-node": "10.9.2",
		"typescript": "7.0.2",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	},
	"engines": {
		"node": "24.18.0"
	}
}
